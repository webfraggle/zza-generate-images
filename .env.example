# HTTP
PORT=8080
BASE_URL=https://zza.example.com

# Templates & Cache
TEMPLATES_DIR=./templates
CACHE_DIR=./cache
CACHE_MAX_AGE_HOURS=24
CACHE_MAX_SIZE_MB=500

# Database
DB_PATH=./data/zza.db

# E-Mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=zza@example.com
SMTP_PASS=REPLACE_WITH_REAL_PASSWORD
SMTP_FROM=zza@example.com

# Editor
EDIT_TOKEN_TTL_HOURS=24

# Admin
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=REPLACE_WITH_64_CHAR_RANDOM_TOKEN
# Generate with: zza totp-setup
TOTP_SECRET=REPLACE_WITH_BASE32_SECRET
